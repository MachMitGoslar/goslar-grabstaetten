HTTP_PORT=8080

POSTGRES_DB=gravedb
POSTGRES_USER=grave
POSTGRES_PASSWORD=grave
POSTGRES_HOST=db

# Optional override for external databases or Plesk setups where the DB is not in the same Compose network.
# DATABASE_URL=postgresql://grave:grave@db:5432/gravedb

# Image prefix used by docker-compose.production.yml.
GHCR_IMAGE_PREFIX=ghcr.io/machmitgoslar/goslar-grabstaetten

# Use latest for default-branch deployments, main for branch tag, sha-<commit> for immutable deployments, or a v* tag.
IMAGE_TAG=latest
